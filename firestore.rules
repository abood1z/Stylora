rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Admins have superuser access to the entire database
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Allow users to read/write their own data and all their subcollections (wardrobe, my_outfits, etc)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow anyone to create a notification for a user, but only the user can read/modify them
    match /users/{userId}/notifications/{notificationId} {
      allow create: if request.auth != null;
    }
    
    // Products: only shop owners can create their own, anyone can read
    match /Products/{productId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
                       (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'merchant' || 
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'trader') &&
                       request.resource.data.storeID == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.storeID == request.auth.uid;
    }
    
    // Orders collection: buyers can create, buyers and sellers can read/update
    match /orders/{orderId} {
      allow create: if request.auth != null && request.resource.data.buyerId == request.auth.uid;
      allow read, update, delete: if request.auth != null && (resource.data.buyerId == request.auth.uid || resource.data.storeID == request.auth.uid);
    }
    
    // User Closet: Only owner can access
    match /User_Closet/{itemId} {
      allow read, delete: if request.auth != null && resource.data.userID == request.auth.uid;
      allow create, update: if request.auth != null && request.resource.data.userID == request.auth.uid;
    }
    
    // App Config & Settings (Public Read)
    match /app_settings/{document=**} { allow read: if true; }
    match /app_config/{document=**} { allow read: if true; }
    
    // Other collections (Logs, Suggestions, Outfits, Stores, Looks)
    match /ai_suggestions/{docId} {
      allow read, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create, update: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    
    match /virtual_tryon_logs/{logId} {
      allow read, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create, update: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    
    match /outfits/{outfitId} {
      allow read, delete: if request.auth != null && resource.data.userID == request.auth.uid;
      allow create, update: if request.auth != null && request.resource.data.userID == request.auth.uid;
    }
    
    match /shop_stores/{storeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == storeId &&
                       (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'merchant' ||
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'trader');
    }
    
    match /daily_looks/{lookId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
  }
}
