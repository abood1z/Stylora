rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow users to read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Products are publicly readable, but only shop owners can write (simplified for request)
    match /Products/{productId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // In production, check for store owner role
    }
    
    // User Closet: Only owner can access
    match /User_Closet/{itemId} {
      allow read, write: if request.auth != null && request.resource.data.userID == request.auth.uid || resource.data.userID == request.auth.uid;
    }
    
    // Existing collections
    match /shop_stores/{storeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /daily_looks/{lookId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
